{
  "patterns": [
    {
      "name": "aws_access_key_id",
      "regex": "AKIA[0-9A-Z]{16}",
      "category": "secrets",
      "severity": "high"
    },
    {
      "name": "openai_api_key",
      "regex": "sk-[A-Za-z0-9]{20,}",
      "category": "secrets",
      "severity": "high"
    },
    {
      "name": "generic_api_key_assignment",
      "regex": "(?i)(api[_-]?key|apikey)\\s*[=:]\\s*['\"][A-Za-z0-9/+._-]{8,}['\"]",
      "category": "secrets",
      "severity": "high"
    },
    {
      "name": "password_in_assignment",
      "regex": "(?i)(password|passwd|pwd)\\s*[=:]\\s*['\"][^'\"]{4,}['\"]",
      "category": "secrets",
      "severity": "high"
    },
    {
      "name": "private_key_header",
      "regex": "-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----",
      "category": "secrets",
      "severity": "critical"
    },
    {
      "name": "github_token",
      "regex": "gh[pousr]_[A-Za-z0-9]{36,}",
      "category": "secrets",
      "severity": "high"
    },
    {
      "name": "generic_secret_assignment",
      "regex": "(?i)(secret|auth_token|access_token)\\s*[=:]\\s*['\"][A-Za-z0-9/+._-]{8,}['\"]",
      "category": "secrets",
      "severity": "medium"
    },
    {
      "name": "prompt_injection_role_override",
      "regex": "(?i)(ignore (previous|all|prior) instructions|disregard (the |your )?(previous|prior|above) (instructions?|prompt|system))",
      "category": "injection",
      "severity": "high"
    },
    {
      "name": "prompt_injection_system_override",
      "regex": "(?i)(you are now|act as|pretend (you are|to be)|your (new |true )?role is)",
      "category": "injection",
      "severity": "medium"
    },
    {
      "name": "prompt_injection_jailbreak",
      "regex": "(?i)(DAN mode|developer mode|jailbreak|bypass (safety|filter|restriction))",
      "category": "injection",
      "severity": "high"
    },
    {
      "name": "eval_with_variable",
      "regex": "\\beval\\s*\\([^)\"'`]*(?:req|input|user|param|query|body|data)[^)]*\\)",
      "category": "unsafe_code",
      "severity": "high"
    },
    {
      "name": "innerHTML_assignment",
      "regex": "\\.innerHTML\\s*[+]?=\\s*(?!\\s*['\"`][^'\"`]*['\"`]\\s*;)",
      "category": "unsafe_code",
      "severity": "medium"
    },
    {
      "name": "sql_string_concatenation",
      "regex": "(?i)(SELECT|INSERT|UPDATE|DELETE|DROP|CREATE)\\b[^;]*\\+\\s*(?:req|input|user|param|query|body|data|\\w+)",
      "category": "unsafe_code",
      "severity": "high"
    },
    {
      "name": "child_process_exec_variable",
      "regex": "(?:exec|execSync|spawn|spawnSync)\\s*\\([^)]*(?:req|input|user|param|query|body|data)[^)]*\\)",
      "category": "unsafe_code",
      "severity": "high"
    }
  ]
}
